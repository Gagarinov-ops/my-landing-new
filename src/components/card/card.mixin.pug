mixin card(icon, title, description, link='#')
  li(class="p-6 rounded-none shadow-lg text-center border border-[var(--accent)]")
    div(class="text-4xl mb-4")= icon
    h3(class="text-xl font-semibold mb-2")= title
    p(class="text-[var(--text-secondary)] opacity-90")= description

mixin cardTitle(title, link='#')
  li
    a(class="text-[var(--accent)] hover:no-underline inline-flex items-center gap-1 focus:outline-none focus:ring-2 focus:ring-[var(--accent)] focus:ring-offset-2 focus:ring-offset-[var(--bg-primary)]" href=link)= title     