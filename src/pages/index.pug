extends ../layouts/default.pug
include ../components/card/card.mixin.pug

block content
  section(
    class="max-w-6xl mx-auto px-4 py-16 text-center",
    aria-labelledby="hero-heading"
  )
    h1#hero-heading(class="text-4xl font-bold mb-4")
      | Готовый сайт для строителя 
      span(class="text-[var(--accent)]") с авторасчётом сметы
    p(class="text-xl text-[var(--text-secondary)] max-w-2xl mx-auto mb-6")
      | Ваши клиенты сами выбирают услуги, видят точную цену и подписывают договор онлайн. Экономия до 10 часов в неделю.
    p(class="text-base text-[var(--text-secondary)] max-w-xl mx-auto")
      | Сайт под ключ, который работает на вас 24/7.
    a(
      href="#contacts",
      class="inline-block mt-8 bg-transparent px-8 py-3 border border-[var(--accent)] rounded-none font-semibold hover:no-underline focus:outline-none focus:ring-2 focus:ring-[var(--accent)] focus:ring-offset-2 focus:ring-offset-[var(--bg-primary)]",
      role="button"
    ) Узнать стоимость и сроки

  section(
    class="max-w-6xl mx-auto px-4 py-16",
    aria-labelledby="benefits-heading"
  )
    h2#benefits-heading(class="sr-only") Преимущества платформы для строителей
    ul(class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8")
      +card('📈', 'Готовые заказы', 'Сайт работает как ваш личный менеджер: клиенты сами оставляют заявки, вы только берёте в работу.')
      +card('🤖', 'Автосметы и договоры', 'Клиент выбирает услуги → система мгновенно считает цену и выдаёт готовый договор. Всё онлайн, без лишних звонков.')
      +card('💰', 'Экономия времени', 'Не нужно объяснять цены по телефону, расписывать сметы вручную, печатать договоры. Всё в одном месте.')

  include ../components/about.pug

  section#contacts(
    class="max-w-6xl mx-auto px-4 py-16 scroll-mt-20",
    aria-labelledby="contacts-heading"
  )
    h2#contacts-heading(class="text-3xl font-bold text-center mb-12 text-[var(--text-primary)]") Связаться со мной
    div(class="flex flex-col md:flex-row gap-12")
      div(class="md:w-1/2 space-y-4")
        h3(class="text-xl font-semibold text-[var(--text-primary)] mb-4") Мои контакты
        div(class="flex items-center gap-3 text-[var(--text-secondary)]")
          span(aria-hidden="true") ✉️
          a(
            href="mailto:gagarinoff.one@yandex.ru",
            class="hover:text-[var(--accent)] transition focus:outline-none focus:ring-2 focus:ring-[var(--accent)] focus:ring-offset-2 focus:ring-offset-[var(--bg-primary)]"
          ) gagarinoff.one@yandex.ru
        div(class="flex items-center gap-3")
          svg(
            xmlns="http://www.w3.org/2000/svg",
            viewBox="0 0 24 24",
            width="24",
            height="24",
            class="shrink-0",
            aria-hidden="true"
          )
            circle(cx="12", cy="12", r="12", fill="#26A5E4")
            path(fill="#FFFFFF", d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.215-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.053-.334-.375-.121l-6.87 4.326-2.96-.924c-.64-.2-.652-.64.135-.953l11.57-4.458c.532-.19.996.128.804.853z")
          a(
            href="https://t.me/@Gagarinoff",
            target="_blank",
            rel="noopener noreferrer",
            class="text-[var(--text-secondary)] hover:text-[var(--accent)] transition focus:outline-none focus:ring-2 focus:ring-[var(--accent)] focus:ring-offset-2 focus:ring-offset-[var(--bg-primary)]"
          ) Telegram
      div(class="md:w-1/2")
        script(src="https://forms.yandex.ru/_static/embed.js")
        iframe(
          src="https://forms.yandex.ru/u/69e8360749af47606525d211?iframe=1",
          frameborder="0",
          name="ya-form-69e8360749af47606525d211",
          width="100%",
          height="600",
          title="Форма обратной связи: заказать сайт или получить консультацию"
        )