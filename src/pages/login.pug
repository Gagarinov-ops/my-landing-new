extends ../layouts/default.pug

block content
  div(class="max-w-md mx-auto mt-16 p-6 bg-[var(--bg-secondary)] rounded-xl border border-[var(--border)]")
    h2(class="text-2xl font-bold mb-6 text-center text-[var(--text-primary)]") Вход в личный кабинет
    form(id="login-form")
      div(class="mb-4")
        label(class="block text-sm font-medium mb-1 text-[var(--text-secondary)]") Логин
        input(
          type="text",
          id="login",
          class="w-full p-2 rounded border border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent)] focus:ring-offset-2 focus:ring-offset-[var(--bg-primary)]"
        )
      div(class="mb-6")
        label(class="block text-sm font-medium mb-1 text-[var(--text-secondary)]") Пароль
        input(
          type="password",
          id="password",
          class="w-full p-2 rounded border border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent)] focus:ring-offset-2 focus:ring-offset-[var(--bg-primary)]"
        )
      button(
        type="submit",
        class="w-full bg-[var(--accent)] text-[var(--bg-primary)] py-2 rounded font-semibold hover:opacity-90 transition focus:outline-none focus:ring-2 focus:ring-[var(--accent)] focus:ring-offset-2"
      ) Войти
    div(id="error-msg", class="text-red-500 text-sm mt-4 text-center hidden") Неверный логин или пароль

  script(src="/js/login.js")